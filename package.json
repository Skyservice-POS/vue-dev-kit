{
  "name": "@skyservice-developers/vue-dev-kit",
  "version": "2.4.1",
  "description": "Vue 3 component library + TypeScript SDK (iframe bridge + HTTP API) for Skyservice mini-apps",
  "type": "module",
  "main": "./dist/vue-dev-kit.cjs",
  "module": "./dist/vue-dev-kit.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-dev-kit.js",
      "require": "./dist/vue-dev-kit.cjs"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk.js",
      "require": "./dist/sdk.cjs"
    },
    "./vue3": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-dev-kit.js",
      "require": "./dist/vue-dev-kit.cjs"
    },
    "./style.css": "./dist/style.css",
    "./vue3/style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "playground": "vite --config playground/vite.config.js playground",
    "build": "vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "release": "npm publish --access public"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "ua-parser-js": "^1.0.37"
  },
  "devDependencies": {
    "@types/ua-parser-js": "^0.7.39",
    "@vitejs/plugin-vue": "^5.0.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.1",
    "vue": "^3.4.21"
  },
  "keywords": [
    "vue",
    "vue3",
    "components",
    "toolkit",
    "ui",
    "skyservice",
    "sdk",
    "iframe",
    "bridge"
  ],
  "author": "Skyservice-POS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Skyservice-POS/vue-dev-kit.git"
  },
  "bugs": {
    "url": "https://github.com/Skyservice-POS/vue-dev-kit/issues"
  },
  "homepage": "https://github.com/Skyservice-POS/vue-dev-kit#readme"
}
